@model OvejaNegra.Models.Usuario

@{
    ViewData["Title"] = "Detalle Usuario";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet">

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>

    body {
        background: #f6f3eb;
        font-family: 'Poppins', sans-serif;
    }

    .card-user {
        max-width: 900px;
        margin: 40px auto;
        background: white;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 4px 18px rgba(0,0,0,.08);
    }

    .card-header-custom {
        padding: 28px 35px;
        border-bottom: 1px solid #ebe6dc;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .title {
        font-size: 40px;
        font-weight: 700;
        color: #111827;
    }

    .close-btn {
        font-size: 28px;
        text-decoration: none;
        color: #6b7280;
    }

    .card-body-custom {
        padding: 40px 35px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 35px;
    }

    .label {
        color: #6b7280;
        font-size: 15px;
        margin-bottom: 6px;
    }

    .value {
        font-size: 28px;
        font-weight: 500;
        color: #111827;
    }

    .badge-role {
        display: inline-block;
        padding: 10px 18px;
        border-radius: 30px;
        font-weight: 600;
        background: #f1dfff;
        color: #8b5cf6;
    }

    .estado {
        display: inline-block;
        padding: 10px 18px;
        border-radius: 30px;
        background: #dcfce7;
        color: #16a34a;
        font-weight: 600;
    }

    .footer {
        padding: 30px 35px;
        border-top: 1px solid #ebe6dc;
    }

    .btn-close-custom {
        width: 100%;
        background: #111827;
        color: white;
        border: none;
        border-radius: 18px;
        padding: 18px;
        font-size: 18px;
        font-weight: 600;
        text-decoration: none;
        display: block;
        text-align: center;
    }

    @@media(max-width:768px) {

        .title {
            font-size: 32px;
        }

        .info-grid {
            grid-template-columns: 1fr;
        }

        .value {
            font-size: 22px;
        }
    }

</style>

<div class="card-user">

    <div class="card-header-custom">

        <div class="title">
            Detalle del Usuario
        </div>

        <a asp-action="Index" class="close-btn">
            <i class="bi bi-x"></i>
        </a>

    </div>

    <div class="card-body-custom">

        <div class="info-grid">

            <div>
                <div class="label">ID</div>
                <div class="value">@Model.Id</div>
            </div>

            <div>
                <div class="label">Estado</div>

                <span class="estado">
                    Activo
                </span>
            </div>

            <div>
                <div class="label">Nombre</div>
                <div class="value">@Model.Nombre</div>
            </div>

            <div>
                <div class="label">Apellido</div>
                <div class="value">@Model.Apellido</div>
            </div>

            <div>
                <div class="label">Username</div>
                <div class="value">@Model.username</div>
            </div>

            <div>
                <div class="label">Password</div>
                <div class="value">@Model.password</div>
            </div>

            <div>
                <div class="label">Rol</div>

                <span class="badge-role">
                    @Model.Rol
                </span>
            </div>

        </div>

    </div>

    <div class="footer">

        <a asp-action="Index"
           class="btn-close-custom">

            Cerrar

        </a>

    </div>

</div>
@model OvejaNegra.Models.Usuario

@{
    ViewData["Title"] = "Editar Usuario";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet">

<style>

    body {
        background: #f6f3eb;
        font-family: 'Poppins',sans-serif;
    }

    .form-card {
        max-width: 900px;
        margin: 40px auto;
        background: white;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 4px 18px rgba(0,0,0,.08);
    }

    .header {
        padding: 28px 35px;
        border-bottom: 1px solid #ebe6dc;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .title {
        font-size: 38px;
        font-weight: 700;
    }

    .body-custom {
        padding: 35px;
    }

    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }

    .full {
        grid-column: 1/3;
    }

    label {
        margin-bottom: 8px;
        font-weight: 500;
    }

    .form-control,
    .form-select {
        height: 58px;
        border-radius: 16px;
    }

    .footer {
        padding: 30px 35px;
        border-top: 1px solid #ebe6dc;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .btn-cancel {
        height: 58px;
        border-radius: 16px;
        border: 1px solid #d1d5db;
        background: white;
        font-weight: 600;
    }

    .btn-save {
        height: 58px;
        border-radius: 16px;
        border: none;
        background: #111827;
        color: white;
        font-weight: 600;
    }

    @@media(max-width:768px) {

        .grid {
            grid-template-columns: 1fr;
        }

        .full {
            grid-column: auto;
        }

        .footer {
            grid-template-columns: 1fr;
        }

        .title {
            font-size: 30px;
        }
    }

</style>

<div class="form-card">

    <div class="header">

        <div class="title">
            Editar Usuario
        </div>

        <a asp-action="Index"
           style="font-size:28px;color:#6b7280;text-decoration:none;">
            ×
        </a>

    </div>

    <form asp-action="Edit">

        <div class="body-custom">

            <input type="hidden" asp-for="Id" />

            <div class="grid">

                <div>
                    <label>Nombre</label>
                    <input asp-for="Nombre"
                           class="form-control" />
                </div>

                <div>
                    <label>Apellido</label>
                    <input asp-for="Apellido"
                           class="form-control" />
                </div>

                <div class="full">
                    <label>Username</label>
                    <input asp-for="username"
                           class="form-control" />
                </div>

                <div class="full">
                    <label>Password</label>
                    <input asp-for="password"
                           class="form-control" />
                </div>

                <div>
                    <label>Rol</label>

                    <select asp-for="Rol"
                            class="form-select">

                        <option value="1">Administrador</option>
                        <option value="2">Cajero</option>
                        <option value="3">Mesero</option>
                        <option value="4">Cocinero</option>

                    </select>
                </div>

                <div>
                    <label>Estado</label>

                    <select class="form-select">

                        <option>Activo</option>

                    </select>
                </div>

            </div>

        </div>

        <div class="footer">

            <a asp-action="Index"
               class="btn btn-cancel">

                Cancelar

            </a>

            <button type="submit"
                    class="btn-save">

                Guardar Cambios

            </button>

        </div>

    </form>

</div>
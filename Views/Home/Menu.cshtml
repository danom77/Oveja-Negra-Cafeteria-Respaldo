
@model IEnumerable<OvejaNegra.Models.Categoria>
@{
    ViewData["Title"] = "Menú";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Menú — Oveja Negra Coffee</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #f6f3eb;
            font-family: 'Poppins', sans-serif;
            color: #111827;
        }
        .menu-hero {
            background: #111827;
            padding: 60px 20px 40px;
            text-align: center;
        }

            .menu-hero img {
                width: 80px;
                height: 80px;
                border-radius: 16px;
                object-fit: cover;
                margin-bottom: 16px;
            }

            .menu-hero h1 {
                font-family: 'Playfair Display', serif;
                font-size: 48px;
                color: white;
                letter-spacing: 1px;
            }

                .menu-hero h1 span {
                    color: #c9956b;
                }

            .menu-hero p {
                color: #9ca3af;
                margin-top: 8px;
                font-size: 15px;
            }

        .cat-nav {
            position: sticky;
            top: 0;
            z-index: 100;
            background: #f6f3eb;
            border-bottom: 1px solid #e5e7eb;
            padding: 14px 20px;
            display: flex;
            gap: 10px;
            overflow-x: auto;
            justify-content: center;
            flex-wrap: wrap;
        }

            .cat-nav::-webkit-scrollbar {
                display: none;
            }

        .cat-pill {
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 30px;
            padding: 8px 20px;
            font-size: 13px;
            font-weight: 600;
            color: #6b7280;
            text-decoration: none;
            transition: .2s;
            white-space: nowrap;
        }

            .cat-pill:hover,
            .cat-pill.active {
                background: #111827;
                color: white;
                border-color: #111827;
            }

        .menu-wrapper {
            max-width: 900px;
            margin: 0 auto;
            padding: 40px 20px 80px;
        }

        .cat-section {
            margin-bottom: 60px;
            scroll-margin-top: 80px;
        }

        .cat-header {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 24px;
        }

            .cat-header h2 {
                font-family: 'Playfair Display', serif;
                font-size: 32px;
                color: #111827;
            }

            .cat-header::after {
                content: '';
                flex: 1;
                height: 1px;
                background: #e5e7eb;
            }

        .productos-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 16px;
        }

        .prod-card {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid #ece7dc;
            transition: .2s;
            display: flex;
            flex-direction: column;
        }

            .prod-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 24px rgba(0,0,0,0.1);
            }

        .prod-img {
            width: 100%;
            height: 160px;
            object-fit: cover;
        }

        .prod-no-img {
            width: 100%;
            height: 160px;
            background: #f3efe7;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 48px;
            color: #c9956b;
        }

        .prod-body {
            padding: 16px;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .prod-nombre {
            font-weight: 700;
            font-size: 16px;
            color: #111827;
            margin-bottom: 6px;
        }

        .prod-desc {
            font-size: 12px;
            color: #6b7280;
            line-height: 1.5;
            margin-bottom: 12px;
        }

        .prod-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .prod-precio {
            font-size: 18px;
            font-weight: 700;
            color: #7c5a27;
        }

            .prod-precio span {
                font-size: 12px;
                font-weight: 500;
                color: #9ca3af;
            }

        .prod-badge {
            background: #f3efe7;
            color: #7c5a27;
            font-size: 11px;
            font-weight: 600;
            padding: 4px 10px;
            border-radius: 20px;
        }

        .menu-footer {
            background: #111827;
            color: #9ca3af;
            text-align: center;
            padding: 30px 20px;
            font-size: 13px;
        }

            .menu-footer strong {
                color: white;
                font-size: 16px;
                display: block;
                margin-bottom: 6px;
                font-family: 'Playfair Display', serif;
            }

        @@media (max-width: 600px) {
            .menu-hero h1 {
                font-size: 32px;
            }

            .productos-grid {
                grid-template-columns: 1fr;
            }

            .cat-header h2 {
                font-size: 24px;
            }
        }
    </style>
</head>
<body>

    <div class="menu-hero">
        <img src="~/imagenes/logo.jpeg" alt="Oveja Negra" />
        <h1>Oveja Negra <span>Coffee</span></h1>
    </div>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div style="background:#f6f3eb; padding:10px 20px; text-align:right; max-width:900px; margin:0 auto;">
            <a asp-controller="Home" asp-action="Index"
               style="background:#111827; color:white; padding:8px 18px; border-radius:12px;
                                      text-decoration:none; font-size:13px; font-weight:600;">
                <i class="bi bi-arrow-left"></i> Volver al sistema
            </a>
        </div>
    }

    <nav class="cat-nav">
        @foreach (var cat in Model)
        {
            <a href="#cat-@cat.Id" class="cat-pill">@cat.Nombre</a>
        }
    </nav>

    <div class="menu-wrapper">
        @foreach (var cat in Model)
        {
            <section class="cat-section" id="cat-@cat.Id">

                <div class="cat-header">
                    <h2>@cat.Nombre</h2>
                </div>
                <div class="productos-grid">
                    @foreach (var prod in cat.Productos)
                    {
                        <div class="prod-card">

                            @if (!string.IsNullOrEmpty(prod.Imagen))
                            {
                                <img src="~/imagenes/@prod.Imagen"
                                     class="prod-img" alt="@prod.Nombre" />
                            }
                            else
                            {
                                <div class="prod-no-img">
                                    <i class="bi bi-cup-hot"></i>
                                </div>
                            }

                            <div class="prod-body">
                                <div>
                                    <div class="prod-nombre">@prod.Nombre</div>
                                    <div class="prod-desc">@prod.Descripcion</div>
                                </div>
                                <div class="prod-footer">
                                    <div class="prod-precio">
                                        Bs. @prod.Precio.ToString("0.00")
                                    </div>
                                    <span class="prod-badge">
                                        <i class="bi bi-check-circle-fill"></i> Disponible
                                    </span>
                                </div>
                            </div>

                        </div>
                    }
                </div>

            </section>
        }
    </div>
    <script>
        const pills = document.querySelectorAll('.cat-pill');
        const sections = document.querySelectorAll('.cat-section');

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    pills.forEach(p => p.classList.remove('active'));
                    const active = document.querySelector(`.cat-pill[href="#${entry.target.id}"]`);
                    if (active) active.classList.add('active');
                }
            });
        }, { threshold: 0.3 });

        sections.forEach(s => observer.observe(s));
    </script>

</body>
</html>
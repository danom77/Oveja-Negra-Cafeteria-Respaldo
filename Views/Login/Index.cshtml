@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Login - Oveja Negra</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">


    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: #f5f1e8;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .login-card {
            background: #ffffff;
            padding: 30px;
            border-radius: 20px;
            width: 350px;
            box-shadow: 0px 10px 25px rgba(0,0,0,0.1);
            text-align: center;
        }

        .logo {
            width: 190px;
            margin-bottom: 1px;
        }

        .title {
            font-weight: 600;
            font-size: 22px;
        }

        .subtitle {
            font-size: 13px;
            color: #777;
            margin-bottom: 20px;
        }

        .form-group {
            text-align: left;
            margin-bottom: 15px;
        }

        .form-label {
            font-size: 13px;
            margin-bottom: 5px;
            display: block;
        }

        .input-icon {
            display: flex;
            align-items: center;
            background: #fff;
            border-radius: 10px;
            padding: 8px;
            border: 1px solid #6B4423;
        }

        .input-icon i {
            margin-right: 8px;
                color: #6B4423;
        }

        .form-control {
            border: none;
            outline: none;
            width: 100%;
            font-size: 14px;
        }

        .extra {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            margin: 10px 0;
        }

        .btn-login {
            width: 100%;
            background: #1e1e1e;
            color: white;
            border: none;
            padding: 12px;
            border-radius: 10px;
            font-weight: 500;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-login:hover {
            background: #333;
        }

        .register {
            font-size: 13px;
            margin-top: 15px;
        }

        .register a {
            color: #000;
            font-weight: 500;
        }

        .alert-error {
            margin-top: 10px;
            color: red;
            font-size: 13px;
        }
    </style>
</head>

<body>

    <div class="login-card">
        <!--Falta logo-->
        <img src="~/imagenes/logo.jpeg" class="logo" alt="Logo Oveja Negra" /> 

        <p style="font-size:13px; color:#6B4423;">Bienvenido de vuelta</p>

        <form asp-controller="Login" asp-action="Login" method="post">

            <div class="form-group">
                <label class="form-label">Nombre de usuario</label>
                <div class="input-icon">
                    <i class="bi bi-envelope"></i>
                    <input class="form-control" type="text" name="username" placeholder="usuario" required />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Contraseña</label>
                <div class="input-icon">
                    <i class="bi bi-lock"></i>
                    <input class="form-control" type="password" name="password" placeholder="********" required />
                </div>
            </div>

            <div class="extra">
                <label><input type="checkbox" /> Recordarme</label>
                <a>¿Olvidaste tu contraseña?</a>
            </div>

            <button type="submit" class="btn-login">
                Iniciar Sesión
            </button>
           
        </form>

        @if (TempData["LoginError"] != null)
        {
            <div class="alert-error">
                @TempData["LoginError"]
            </div>
        }
            
    </div>

</body>

</html>

@using Microsoft.AspNetCore.Identity;
@using System.Security.Claims;
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OvejaNegra</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

</head>
<body style="min-height:100vh; display:flex; flex-direction:column;">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light border-bottom mb-3">
            <div class="container-fluid">

                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/imagenes/logo.jpeg" alt="Logo"
                         style="width:36px; height:36px; border-radius:8px; object-fit:cover;" />
                    OvejaNegra
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        @if (User.IsInRole("Mesero"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Comandas" asp-action="Index">Pedidos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Productoes" asp-action="Index">Productos</a>
                            </li>
                        }
                        @if (User.IsInRole("Cajero"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Comandas" asp-action="Index">Pedidos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Categorias" asp-action="Index">Categorias</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Productoes" asp-action="Index">Productos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Ventas" asp-action="Index">Ventas</a>
                            </li>
                        }
                        @if (User.IsInRole("Administrador"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Comandas" asp-action="Index">Pedidos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Usuarios" asp-action="Index">Usuarios</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Ventas" asp-action="Index">Ventas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Productoes" asp-action="Index">Productos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Categorias" asp-action="Index">Categorias</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Reportes" asp-action="Index">Reportes</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Menu">Reportes</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-2">
                        <span class="navbar-text">
                            <i class="bi bi-person-fill"></i>
                            @User.Identity?.Name &nbsp;|&nbsp;
                            <i></i>
                            @User.FindFirstValue(ClaimTypes.Role)
                        </span>

                        <a class="btn-salir" asp-controller="Login" asp-action="Logout"
                           title="Salir">
                            <i class="bi bi-box-arrow-right"></i>
                        </a>
                    </div>
                </div>

            </div>
        </nav>
    </header>

    <div class="container container-main" style="flex:1;">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer">
        <div class="container">
            &copy; 2026 - OvejaNegra
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@model OvejaNegra.ViewModels.CrearComandaVM

<style>

    .categoria-btn {
        border: none;
        padding: 10px 18px;
        border-radius: 12px;
        background: #e8e3d9;
        margin-right: 10px;
        cursor: pointer;
    }

        .categoria-btn.active {
            background: #1f1f1f;
            color: white;
        }

    .card-producto {
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        background: white;
        transition: 0.2s;
    }

        .card-producto:hover {
            transform: scale(1.03);
        }

    .card-img {
        height: 150px;
        object-fit: cover;
        width: 100%;
    }

    .precio {
        font-weight: bold;
        color: #7a5c2e;
    }

    .contador {
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .contador button {
            border: none;
            padding: 5px 10px;
            border-radius: 8px;
            background: #eee;
        }

    .carrito {
        background: #fff;
        border-radius: 16px;
        padding: 15px;
        margin-top: 30px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
</style>

<h2>Nuevo Pedido</h2>

<div class="mb-3">
    <label>Mesa:</label>
    <select id="mesa" class="form-control">
        <option value="">Seleccione mesa</option>

        @foreach (var mesa in Model.MesasDisponibles)
        {
            <option value="@mesa">
                Mesa @mesa
            </option>
        }
    </select>
</div>

<div class="d-flex mb-4">
    @foreach (var cat in Model.Categorias)
    {
        <button class="categoria-btn" onclick="filtrar(@cat.Id, this)">
            @cat.Nombre
        </button>
    }
</div>


<div class="row" id="productos">
    @foreach (var cat in Model.Categorias)
    {
        foreach (var prod in cat.Productos)
        {
            <div class="col-md-3 mb-4 producto" data-cat="@cat.Id">
                <div class="card-producto">
                    <img src="@(string.IsNullOrEmpty(prod.Imagen)
                             ? "/imagen/no-image.jpeg"
                             : prod.Imagen)"
                         class="card-img" />


                    <div class="p-3">
                        <h5>@prod.Nombre</h5>
                        <div class="precio">@prod.Precio Bs.</div>

                        <div class="contador mt-2">
                            <button onclick="cambiar(@prod.Id, -1)">-</button>
                            <span id="cant-@prod.Id">0</span>
                            <button onclick="cambiar(@prod.Id, 1)">+</button>
                        </div>

                        <input type="text"
                               id="obs-@prod.Id"
                               class="form-control mt-2"
                               placeholder="Observación..." />
                    </div>

                </div>
            </div>
        }
    }
</div>


<div class="carrito">
    <div class="d-flex justify-content-between">
        <h5>Productos Seleccionados</h5>
        <button class="btn btn-sm btn-danger" onclick="limpiar()">Limpiar</button>
    </div>

    <ul id="lista"></ul>

    <h4>Total: <span id="total">0</span> Bs.</h4>

    <button class="btn btn-success w-100" onclick="guardar()">Guardar Pedido</button>
</div>

<script>
    let carrito = {};
    let precios = {};
    let nombres = {};

        document.querySelectorAll("[id^='cant-']").forEach(el => {
        let id = el.id.split("-")[1];
        let card = el.closest(".card-producto");

        let nombre = card.querySelector("h5").innerText;
        let precioTexto = card.querySelector(".precio").innerText;

        let precioLimpio = precioTexto.replace("Bs.", "").replace(/\s/g, "").replace(",", ".");
        let precio = parseFloat(precioLimpio);

        console.log(`Producto ${id}: texto="${precioTexto}" -> limpio="${precioLimpio}" -> numero=${precio}`);

        nombres[id] = nombre;
        precios[id] = precio;
    });

    function filtrar(id, btn) {
        document.querySelectorAll(".producto").forEach(p => {
            p.style.display = p.dataset.cat == id ? "block" : "none";
        });

        document.querySelectorAll(".categoria-btn").forEach(b => b.classList.remove("active"));
        btn.classList.add("active");
    }

    function cambiar(id, val) {

        if (!carrito[id]) {
            carrito[id] = {
                cantidad: 0,
                observacion: ""
            };
        }

        carrito[id].cantidad += val;
        if (carrito[id].cantidad < 0) carrito[id].cantidad = 0;

        carrito[id].observacion = document.getElementById("obs-" + id).value;

        document.getElementById("cant-" + id).innerText = carrito[id].cantidad;

        render();
    }

    function render() {
        let lista = document.getElementById("lista");
        lista.innerHTML = "";
        let total = 0;

        for (let id in carrito) {
            let item = carrito[id];

            if (item.cantidad > 0) {

                let li = document.createElement("li");

                li.innerText =
                    nombres[id] + " x " + item.cantidad +
                    (item.observacion ? " (" + item.observacion + ")" : "");

                lista.appendChild(li);

                total += item.cantidad * precios[id];
            }
        }

        document.getElementById("total").innerText = total.toFixed(2);
    }

    function limpiar() {
        carrito = {};
        document.querySelectorAll("[id^='cant-']").forEach(el => el.innerText = "0");
        render();
    }

    function guardar() {
        let mesa = parseInt(document.getElementById("mesa").value);

        if (!mesa || isNaN(mesa)) {
            alert("Por favor seleccione una mesa.");
            return;
        }

        for (let id in carrito) {
            let obsEl = document.getElementById("obs-" + id);
            if (obsEl) carrito[id].observacion = obsEl.value;
        }

        let itemsFiltrados = {};
        for (let id in carrito) {
            if (carrito[id].cantidad > 0) {
                itemsFiltrados[id] = carrito[id];
            }
        }

        if (Object.keys(itemsFiltrados).length === 0) {
            alert("Agregue al menos un producto.");
            return;
        }

        fetch('/Comandas/CrearPedido', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                nroMesa: mesa,
                items: itemsFiltrados
            })
        })
        .then(r => r.json())
        .then(d => {
            if (d.ok) {
                window.location.href = d.redirect;
            } else {
                alert("Error: " + d.msg);
            }
        })
        .catch(() => alert("Error al guardar el pedido."));
    }
</script>
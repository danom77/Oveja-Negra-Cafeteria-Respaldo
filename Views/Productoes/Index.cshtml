@model IEnumerable<OvejaNegra.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet">

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>

    body {
        background: #f6f3eb;
        font-family: 'Poppins', sans-serif;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 28px;
        flex-wrap: wrap;
        gap: 20px;
    }

    .title {
        font-size: 42px;
        font-weight: 700;
        color: #111827;
    }

    .subtitle {
        color: #6b7280;
        margin-top: -5px;
    }

    .btn-add {
        background: #111827;
        color: white;
        padding: 14px 24px;
        border-radius: 16px;
        text-decoration: none;
        font-weight: 600;
        transition: .2s;
    }

        .btn-add:hover {
            color: white;
            transform: translateY(-2px);
        }

    .table-card {
        background: white;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 4px 18px rgba(0,0,0,.08);
        border: 1px solid #ebe6dc;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
    }

        .custom-table thead {
            background: #faf8f3;
        }

        .custom-table th {
            padding: 22px 20px;
            font-size: 14px;
            color: #111827;
            font-weight: 600;
            text-align: left;
        }

        .custom-table td {
            padding: 18px 20px;
            border-top: 1px solid #f1ede5;
            vertical-align: middle;
            color: #374151;
        }

    .product-img {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        object-fit: cover;
    }

    .product-name {
        font-weight: 600;
        color: #111827;
    }

    .price {
        font-weight: 700;
        color: #7c5a27;
    }

    .estado {
        padding: 8px 14px;
        border-radius: 30px;
        font-size: 13px;
        font-weight: 600;
        display: inline-block;
    }

    .disponible {
        background: #dcfce7;
        color: #16a34a;
    }

    .nodisponible {
        background: #fee2e2;
        color: #dc2626;
    }

    .categoria-badge {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 30px;
        background: #fef3c7;
        color: #92400e;
        font-size: 13px;
        font-weight: 600;
    }

    .acciones {
        display: flex;
        gap: 18px;
    }

        .acciones a {
            text-decoration: none;
            font-size: 20px;
            transition: .2s;
        }

    .editar {
        color: #7c5a27;
    }

    .eliminar {
        color: #dc2626;
    }

    .acciones a:hover {
        transform: scale(1.15);
    }

    .descripcion {
        max-width: 280px;
        color: #6b7280;
    }

    @@media(max-width: 1200px) {

        .table-card {
            overflow-x: auto;
        }

        .custom-table {
            min-width: 1100px;
        }
    }

    @@media(max-width: 768px) {

        .title {
            font-size: 32px;
        }

        .btn-add {
            width: 100%;
            text-align: center;
        }
    }

</style>

<div class="container mt-4">

    <!-- HEADER -->

    <div class="page-header">

        <div>

            <div class="title">
                Gestión de Productos
            </div>

            <div class="subtitle">
                Administra el menú de la cafetería
            </div>

        </div>

        <a asp-action="Create"
           class="btn-add">

            <i class="bi bi-plus-lg"></i>
            Añadir Producto

        </a>

    </div>

    <!-- TABLA -->

    <div class="table-card">

        <table class="custom-table">

            <thead>

                <tr>

                    <th>Imagen</th>

                    <th>Nombre</th>

                    <th>Precio</th>

                    <th>Estado</th>

                    <th>Descripción</th>

                    <th>Categoría</th>

                    <th>Acciones</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <!-- IMAGEN -->

                        <td>

                            @if (!string.IsNullOrEmpty(item.Imagen))
                            {
                                <img src="~/imagenes/@item.Imagen"
                                     class="product-img"
                                     asp-append-version="true" />
                            }
                            else
                            {
                                <img src="https://via.placeholder.com/60"
                                     class="product-img" />
                            }

                        </td>

                        <!-- NOMBRE -->

                        <td class="product-name">
                            @item.Nombre
                        </td>

                        <!-- PRECIO -->

                        <td class="price">
                            @item.Precio Bs.
                        </td>

                        <!-- ESTADO -->

                        <td>

                            @if (item.Disponible)
                            {
                                <span class="estado disponible">
                                    Disponible
                                </span>
                            }
                            else
                            {
                                <span class="estado nodisponible">
                                    No Disponible
                                </span>
                            }

                        </td>

                        <!-- DESCRIPCION -->

                        <td class="descripcion">
                            @item.Descripcion
                        </td>

                        <!-- CATEGORIA -->

                        <td>

                            <span class="categoria-badge">
                                @item.Categoria?.Nombre
                            </span>

                        </td>

                        <!-- ACCIONES -->

                        <td>

                            <div class="acciones">

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="editar">

                                    <i class="bi bi-pencil-square"></i>

                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="eliminar">

                                    <i class="bi bi-trash"></i>

                                </a>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>